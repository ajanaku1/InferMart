# ─── InferMart env (copy to .env, never commit .env) ───

# ── Seller identity (QVAC) ──
# 64-char hex seed → deterministic Holepunch/provider public key across reboots.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QVAC_HYPERSWARM_SEED=

# Local GGUF model the seller hosts (1B-Q4 ~0.7GB recommended for the demo).
SELLER_MODEL_PATH=./models/model.gguf
SELLER_MODEL_ID=infermart-1b-q4

# ── Discovery (mocked, by design) ──
# Printed by the seller process on boot — paste it into the buyer's env.
SELLER_PROVIDER_PUBLIC_KEY=
# Seller's WDK USDT receive address — paste into the buyer's env.
SELLER_USDT_ADDRESS=

# ── WDK wallets (NEVER commit real values) ──
# Each peer loads its own mnemonic/private key from its own .env.
SELLER_WALLET_MNEMONIC=
BUYER_WALLET_MNEMONIC=

# ── Settlement (EVM Sepolia) ──
CHAIN=sepolia
CHAIN_ID=11155111
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Test USDT ERC-20 (6 decimals) on Sepolia. Set to your funded faucet token, or the
# address printed by `npm run deploy-usdt` after you deploy the bundled MockUSDT.
USDT_CONTRACT=
USDT_DECIMALS=6
# Price: integer USDT base-units (6 decimals) charged per 1000 generated tokens.
PRICE_PER_1K_TOKENS_BASEUNITS=1000
# Buyer hard cap per session, in USDT base-units (6 decimals). 1_000000 = 1 USDT.
SESSION_SPEND_CAP_BASEUNITS=1000000

# ── Dashboards ──
SELLER_DASHBOARD_PORT=4802
BUYER_DASHBOARD_PORT=4801
